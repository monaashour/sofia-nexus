{
  "name": "sofia-nexus",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --open",
    "dev:backend": "cmd /c \"py -m pip show uvicorn >nul 2>&1 || py -m pip install -r backend\\requirements.txt && py -m uvicorn backend.main:app --reload --host 0.0.0.0 --port 8000\"",
    "dev:all": "cmd /c \"start \"\"FRONTEND\"\" cmd /c \"\"npm run dev\"\" && npm run dev:backend\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.4"
  }
}
